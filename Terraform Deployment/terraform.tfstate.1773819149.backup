    {
      "mode": "managed",
      "type": "kubernetes_daemonset",
      "name": "go_apm_exporter",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 1,
          "attributes": {
            "id": "monitoring/exporter-agent",
            "metadata": [
              {
                "annotations": {},
                "generate_name": "",
                "generation": 1,
                "labels": {
                  "app": "site24x7-go-apm"
                },
                "name": "exporter-agent",
                "namespace": "monitoring",
                "resource_version": "1699",
                "uid": "aeae090e-d9f0-4a6c-a374-7cf7383ae8f6"
              }
            ],
            "spec": [
              {
                "min_ready_seconds": 0,
                "revision_history_limit": 10,
                "selector": [
                  {
                    "match_expressions": [],
                    "match_labels": {
                      "app": "site24x7-go-apm"
                    }
                  }
                ],
                "strategy": [
                  {
                    "rolling_update": [
                      {
                        "max_surge": "0",
                        "max_unavailable": "1"
                      }
                    ],
                    "type": "RollingUpdate"
                  }
                ],
                "template": [
                  {
                    "metadata": [
                      {
                        "annotations": {},
                        "generate_name": "",
                        "generation": 0,
                        "labels": {
                          "app": "site24x7-go-apm"
                        },
                        "name": "",
                        "namespace": "",
                        "resource_version": "",
                        "uid": ""
                      }
                    ],
                    "spec": [
                      {
                        "active_deadline_seconds": 0,
                        "affinity": [],
                        "automount_service_account_token": true,
                        "container": [
                          {
                            "args": [
                              "# Run the normal startup in background\n/tmp/agent-installer/startup.sh \u0026\nSTARTUP_PID=$!\n\n# Wait for the config to be fully generated (check for license key, not placeholder)\necho \"[FIX] Waiting for Go agent config with real license key...\"\nfor i in $(seq 1 180); do\n  if [ -f /opt/site24x7/apm-insight-go-agent/conf/configuration.json ]; then\n    if grep -q \"$$S247_LICENSE_KEY\" /opt/site24x7/apm-insight-go-agent/conf/configuration.json; then\n      echo \"[FIX] Config file ready with license key (waited ${i}s)\"\n      break\n    fi\n  fi\n  sleep 1\ndone\n\n# Patch localhost to 127.0.0.1\nif [ -f /opt/site24x7/apm-insight-go-agent/conf/configuration.json ]; then\n  sed -i 's/localhost/127.0.0.1/g' /opt/site24x7/apm-insight-go-agent/conf/configuration.json\n  echo \"[FIX] Patched config:\"\n  cat /opt/site24x7/apm-insight-go-agent/conf/configuration.json\n\n  # Restart ONLY the Go agent (not the DataExporter)\n  echo \"[FIX] Restarting Go agent...\"\n  pkill -x apm-insight-go-agent 2\u003e/dev/null || true\n  sleep 3\n  echo \"[FIX] Done\"\nfi\n\n# Keep container alive by waiting on startup.sh\nwait $STARTUP_PID\n"
                            ],
                            "command": [
                              "/bin/bash",
                              "-c"
                            ],
                            "env": [
                              {
                                "name": "S247_LICENSE_KEY",
                                "value": "",
                                "value_from": [
                                  {
                                    "config_map_key_ref": [
                                      {
                                        "key": "S247_LICENSE_KEY",
                                        "name": "zylkerkart-config",
                                        "optional": false
                                      }
                                    ],
                                    "field_ref": [],
                                    "resource_field_ref": [],
                                    "secret_key_ref": []
                                  }
                                ]
                              },
                              {
                                "name": "GO_APPS",
                                "value": "",
                                "value_from": [
                                  {
                                    "config_map_key_ref": [
                                      {
                                        "key": "go_apps",
                                        "name": "apm-apps-config",
                                        "optional": false
                                      }
                                    ],
                                    "field_ref": [],
                                    "resource_field_ref": [],
                                    "secret_key_ref": []
                                  }
                                ]
                              }
                            ],
                            "env_from": [],
                            "image": "site24x7/apminsight-go-agent:latest",
                            "image_pull_policy": "Always",
                            "lifecycle": [],
                            "liveness_probe": [],
                            "name": "exporter-agent",
                            "port": [],
                            "readiness_probe": [],
                            "resources": [
                              {
                                "limits": {
                                  "cpu": "300m",
                                  "memory": "256Mi"
